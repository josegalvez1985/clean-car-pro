{
  "buildCommand": "VITE_API_URL=/api VITE_BASE_PATH=/ npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://oracleapex.com/ords/wksp_evamar/api/:path*"
    },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
